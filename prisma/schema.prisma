generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id               String             @id @default(cuid())
  name             String
  targetReaction   String
  conditions       String
  selectivityGoal  Float
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  candidates       Candidate[]
  residualAnalyses ResidualAnalysis[]
  retrainLogs      RetrainLog[]
  modelCheckpoints ModelCheckpoint[]
}

model Candidate {
  id                   String              @id @default(cuid())
  projectId            String
  name                 String
  formula              String
  type                 String // KNOWN | NOVEL
  performanceScore     Float
  procurementScore     Float
  predictedActivity    Float
  predictedSelectivity Float
  predictedStability   Float
  failureRiskTags      String // JSON array
  source               String
  createdAt            DateTime            @default(now())
  project              Project             @relation(fields: [projectId], references: [id])
  experimentOutcomes   ExperimentOutcome[]
}

model ExperimentOutcome {
  id                 String      @id @default(cuid())
  candidateId        String
  actualYield        Float
  actualSelectivity  Float
  actualStability    Float
  result             String // EXCEEDED | MATCHED | UNDERPERFORMED
  voiceNote          String?
  loggedBy           String
  loggedAt           DateTime    @default(now())
  candidate          Candidate   @relation(fields: [candidateId], references: [id])
  voiceNotes         VoiceNote[]
}

model ResidualAnalysis {
  id                 String   @id @default(cuid())
  projectId          String
  runAt              DateTime @default(now())
  hypothesis         String
  shapFeatures       String // JSON
  underperformers    String // JSON
  checkpointVersion  String
  project            Project  @relation(fields: [projectId], references: [id])
}

model RetrainLog {
  id                 String   @id @default(cuid())
  projectId          String
  triggeredAt        DateTime @default(now())
  newPointCount      Int
  checkpointVersion  String
  status             String // PENDING | PROMOTED | ROLLED_BACK
  validationScore    Float
  project            Project  @relation(fields: [projectId], references: [id])
}

model SupplierRegistry {
  id            String  @id @default(cuid())
  precursorName String
  supplier      String
  leadTimeDays  Int
  available     Boolean
  region        String
}

model VoiceNote {
  id               String            @id @default(cuid())
  outcomeId        String
  rawText          String
  language         String
  structuredData   String // JSON
  confidence       Float
  experimentOutcome ExperimentOutcome @relation(fields: [outcomeId], references: [id])
}

model ModelCheckpoint {
  id              String   @id @default(cuid())
  projectId       String
  version         String
  trainedAt       DateTime @default(now())
  validationScore Float
  status          String // ACTIVE | ROLLED_BACK
  lineage         String // JSON
  project         Project  @relation(fields: [projectId], references: [id])
}
